# Neon PostgreSQL connection strings
# Get both from your Neon dashboard: https://neon.tech
# Use the pooled connection for DATABASE_URL, direct for DIRECT_URL
DATABASE_URL="postgresql://USER:PASS@HOST/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST/DBNAME?sslmode=require"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace_with_random_secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

NEXT_PUBLIC_APP_NAME="Beckon"
